{
  "name": "web-qa-automation-tool",
  "version": "1.0.0",
  "description": "Reusable Playwright QA automation tool for web product health checks",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --project=smoke",
    "test:regression": "playwright test --project=regression",
    "test:crawler": "playwright test --project=crawler",
    "crawl:discover": "playwright test --project=crawler-discover",
    "crawl:validate": "playwright test --project=crawler-validate",
    "crawl:full": "npm run crawl:discover && npm run crawl:validate",
    "test:crawl": "npm run crawl:full",
    "test:nightly": "playwright test --project=nightly",
    "test:all": "playwright test --project=smoke --project=regression --project=crawler",
    "test:integration": "playwright test --project=integration",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "ui": "playwright test --ui",
    "agent:ux": "ts-node agent/run.ts",
    "agent:ux:headed": "cross-env HEADLESS=false ts-node agent/run.ts"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "testing",
    "web-qa",
    "e2e",
    "crawler",
    "quality-gates"
  ],
  "author": "Zuna",
  "license": "ISC",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
